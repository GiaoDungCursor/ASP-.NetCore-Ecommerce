@using SV22T1020590.Models.Catalog
@using SV22T1020590.Models.Partner
@model List<Product>
@{
    ViewBag.Title = "Quản lý Mặt hàng";
    var searchValue = ViewBag.SearchValue as string ?? "";
    var supplierID = ViewBag.SupplierID as int?;
    var categoryID = ViewBag.CategoryID as int?;
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var currentPage = (int)ViewBag.CurrentPage;
    var totalRecords = (int)ViewBag.TotalRecords;
    var totalPages = (int)ViewBag.TotalPages;
    var pageSize = (int)(ViewBag.PageSize ?? 10);
    var suppliers = ViewBag.Suppliers as List<Supplier> ?? new List<Supplier>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

@section PageToolBar {
    <a href="@Url.Action("Edit", "Product")" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index" asp-controller="Product">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" name="categoryID">
                        <option value="">-- Tất cả --</option>
                        @foreach (var item in categories)
                        {
                            <option value="@item.CategoryID" selected="@(categoryID == item.CategoryID)">@item.CategoryName</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" name="supplierID">
                        <option value="">-- Tất cả --</option>
                        @foreach (var item in suppliers)
                        {
                            <option value="@item.SupplierID" selected="@(supplierID == item.SupplierID)">@item.SupplierName</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="number" step="0.01" min="0" name="minPrice" value="@minPrice" class="form-control" placeholder="Từ" />
                        <span class="input-group-text">-</span>
                        <input type="number" step="0.01" min="0" name="maxPrice" value="@maxPrice" class="form-control" placeholder="Đến" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text" name="searchValue" value="@searchValue" class="form-control" placeholder="Tên mặt hàng..." autofocus />
                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@totalRecords</strong> mặt hàng. Trang <strong>@currentPage/@totalPages</strong>
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px;">Ảnh</th>
                    <th>Mặt hàng</th>
                    <th style="width:120px;">Đơn vị</th>
                    <th style="width:120px;">Giá</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:140px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var thumb = string.IsNullOrWhiteSpace(item.Photo)
                            ? Url.Content("~/images/products/nophoto.png")
                            : (item.Photo.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                                ? item.Photo
                                : (item.Photo.StartsWith("/images/products/", StringComparison.OrdinalIgnoreCase)
                                    ? item.Photo
                                    : Url.Content("~/images/products/" + item.Photo.TrimStart('/'))));

                        <tr>
                            <td class="text-center">
                                <img src="@thumb" class="img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;" alt="@item.ProductName" />
                            </td>
                            <td>
                                <strong>@item.ProductName</strong><br />
                                <small class="text-muted">@item.ProductDescription</small>
                            </td>
                            <td>@item.Unit</td>
                            <td class="text-end text-danger">@item.Price.ToString("N0")</td>
                            <td class="text-center">
                                @if (item.IsSelling)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="@Url.Action("Edit", "Product", new { id = item.ProductID })" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="@Url.Action("Delete", "Product", new { id = item.ProductID })" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">Không có mặt hàng</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        var maxVisible = 7;
        var half = maxVisible / 2;
        var start = Math.Max(1, currentPage - half);
        var end = Math.Min(totalPages, start + maxVisible - 1);
        if (end - start + 1 < maxVisible)
        {
            start = Math.Max(1, end - maxVisible + 1);
        }

        <div class="card-footer text-center">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", "Product", new { searchValue, supplierID, categoryID, minPrice, maxPrice, page = currentPage - 1, pageSize })">«</a>
                    </li>
                }

                @if (start > 1)
                {
                    <li class="page-item"><a class="page-link" href="@Url.Action("Index", "Product", new { searchValue, supplierID, categoryID, minPrice, maxPrice, page = 1, pageSize })">1</a></li>
                    if (start > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                @for (int p = start; p <= end; p++)
                {
                    if (p == currentPage)
                    {
                        <li class="page-item active"><span class="page-link">@p</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", "Product", new { searchValue, supplierID, categoryID, minPrice, maxPrice, page = p, pageSize })">@p</a>
                        </li>
                    }
                }

                @if (end < totalPages)
                {
                    if (end < totalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item"><a class="page-link" href="@Url.Action("Index", "Product", new { searchValue, supplierID, categoryID, minPrice, maxPrice, page = totalPages, pageSize })">@totalPages</a></li>
                }

                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", "Product", new { searchValue, supplierID, categoryID, minPrice, maxPrice, page = currentPage + 1, pageSize })">»</a>
                    </li>
                }
            </ul>
        </div>
    }
</div>
