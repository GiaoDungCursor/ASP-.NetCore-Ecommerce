@using SV22T1020590.Models.Sales
@model SV22T1020590.Models.Sales.Order
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    var details = Model.OrderDetails ?? new List<OrderDetail>();
    int.TryParse(Model.Status?.Trim(), out var statusCode);
    var alertClass = "secondary";
    string? statusMoment = null;
    switch (statusCode)
    {
        case (int)OrderStatusEnum.Completed:
            alertClass = "success";
            statusMoment = Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm");
            break;
        case (int)OrderStatusEnum.Rejected:
        case (int)OrderStatusEnum.Cancelled:
            alertClass = "danger";
            statusMoment = Model.OrderTime.ToString("dd/MM/yyyy HH:mm");
            break;
        case (int)OrderStatusEnum.Shipping:
            alertClass = "primary";
            statusMoment = Model.ShippedTime?.ToString("dd/MM/yyyy HH:mm");
            break;
        case (int)OrderStatusEnum.Accepted:
            alertClass = "info";
            statusMoment = Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm");
            break;
        default:
            statusMoment = Model.OrderTime.ToString("dd/MM/yyyy HH:mm");
            break;
    }
    var statusText = Model.StatusDescription ?? Model.Status ?? "—";
}

@section PageToolBar {
    <div class="btn-group">
        <button type="button"
                class="btn btn-primary dropdown-toggle"
                data-bs-toggle="dropdown"
                aria-expanded="false">
            <i class="bi bi-gear me-1"></i>
            Xử lý đơn hàng
        </button>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item open-modal" href="~/Order/Accept/@Model.OrderID">Duyệt đơn hàng</a></li>
            <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển giao hàng</a></li>
            <li><a class="dropdown-item open-modal" href="~/Order/Finish/@Model.OrderID">Hoàn tất đơn hàng</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
            <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/@Model.OrderID">Từ chối đơn hàng</a></li>
        </ul>
    </div>

    <a href="~/Order/Delete/@Model.OrderID" class="btn btn-danger ms-1 open-modal">
        <i class="bi bi-trash"></i>
        Xóa
    </a>

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="alert alert-@alertClass d-flex align-items-center mb-3">
    <i class="bi bi-info-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @statusText
        @if (!string.IsNullOrEmpty(statusMoment))
        {
            <span class="ms-1">(<b>@statusMoment</b>)</span>
        }
    </div>
</div>

<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i>
            Thông tin đơn hàng
        </h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>
            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@(Model.EmployeeID?.ToString() ?? "—")</div>
            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@(Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
        </div>
    </div>
</div>

<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Thông tin khách hàng
        </h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@(Model.CustomerName ?? "—")</div>
            <div class="col-md-3 fw-bold">Mã khách hàng</div>
            <div class="col-md-3">@(Model.CustomerID?.ToString() ?? "—")</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@(Model.CustomerEmail ?? "—")</div>
        </div>
    </div>
</div>

<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-truck me-2"></i>
            Thông tin giao hàng
        </h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@(Model.ShipperName ?? "—")</div>
            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@(Model.ShipperPhone ?? "—")</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@(Model.DeliveryAddress ?? "—")</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@(Model.DeliveryProvince ?? "—")</div>
        </div>
    </div>
</div>

<div class="card card-secondary card-outline">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Danh sách mặt hàng
        </h5>
        <form method="post" asp-action="ClearCart" class="m-0" onsubmit="return confirm('Xóa tất cả mặt hàng?');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.OrderID" />
            <button type="submit" class="btn btn-sm btn-danger">
                <i class="bi bi-trash"></i> Xóa giỏ hàng
            </button>
        </form>
    </div>
    <div class="card-body table-responsive p-0 p-md-3">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Mã SP</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @if (details.Count > 0)
                {
                    var i = 0;
                    foreach (var item in details)
                    {
                        i++;
                        <tr>
                            <td class="text-center">@i</td>
                            <td>@item.ProductID</td>
                            <td class="text-center">—</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end">@((item.Quantity * item.SalePrice).ToString("N0"))</td>
                            <td class="text-end text-nowrap">
                                <a href="@Url.Action("EditCartItem", "Order", new { id = Model.OrderID, productId = item.ProductID })"
                                   class="btn btn-sm btn-primary open-modal">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" asp-action="DeleteCartItem" class="d-inline" onsubmit="return confirm('Xóa mặt hàng này khỏi đơn?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.OrderID" />
                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                    <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">Chưa có mặt hàng</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@details.Sum(x => x.Quantity * x.SalePrice).ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
        }
        .card-body .row:last-child {
            border-bottom: none;
        }
    </style>
}
