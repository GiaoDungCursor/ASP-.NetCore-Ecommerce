@using SV22T1020590.Models.Sales
@model List<SV22T1020590.Models.Sales.Order>
@{
    Layout = null;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalRecords = (int)(ViewBag.TotalRecords ?? 0);
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@totalRecords</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        var badgeClass = "bg-secondary";
                        if (item.Status == ((int)OrderStatusEnum.New).ToString()) badgeClass = "bg-warning text-dark";
                        else if (item.Status == ((int)OrderStatusEnum.Accepted).ToString()) badgeClass = "bg-info";
                        else if (item.Status == ((int)OrderStatusEnum.Shipping).ToString()) badgeClass = "bg-primary";
                        else if (item.Status == ((int)OrderStatusEnum.Completed).ToString()) badgeClass = "bg-success";
                        else if (item.Status == ((int)OrderStatusEnum.Cancelled).ToString() || item.Status == ((int)OrderStatusEnum.Rejected).ToString()) badgeClass = "bg-danger";
                        <tr>
                            <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(item.CustomerName ?? "—")</td>
                            <td>@(item.CustomerPhone ?? "—")</td>
                            <td>@(item.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                            <td>@(item.EmployeeName ?? "—")</td>
                            <td class="text-end">@item.TotalAmount.ToString("N0")</td>
                            <td class="text-center">
                                <span class="badge @badgeClass">@(item.StatusDescription ?? item.Status ?? "Không xác định")</span>
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-receipt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">Không có đơn hàng phù hợp</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="card-footer">
            @{
                int maxVisible = 7;
                int half = maxVisible / 2;
                int start = Math.Max(1, currentPage - half);
                int end = Math.Min(totalPages, start + maxVisible - 1);
                if (end - start + 1 < maxVisible)
                {
                    start = Math.Max(1, end - maxVisible + 1);
                }
            }
            <div class="text-center mb-2">
                <div class="mb-1 text-muted">Tổng cộng: <strong>@totalPages</strong> trang</div>
                <nav aria-label="Pagination">
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @Math.Max(1, currentPage - 1))">«</a>
                        </li>

                        @if (start > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:;"
                                   onclick="paginationSearch(event, document.getElementById('formSearch'), 1)">1</a>
                            </li>
                            @if (start > 2)
                            {
                                <li class="page-item disabled"><span class="page-link">…</span></li>
                            }
                        }

                        @for (int p = start; p <= end; p++)
                        {
                            <li class="page-item @(p == currentPage ? "active" : "")">
                                <a class="page-link" href="javascript:;"
                                   onclick="paginationSearch(event, document.getElementById('formSearch'), @p)">@p</a>
                            </li>
                        }

                        @if (end < totalPages)
                        {
                            if (end < totalPages - 1)
                            {
                                <li class="page-item disabled"><span class="page-link">…</span></li>
                            }
                            <li class="page-item">
                                <a class="page-link" href="javascript:;"
                                   onclick="paginationSearch(event, document.getElementById('formSearch'), @totalPages)">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @Math.Min(totalPages, currentPage + 1))">»</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>
