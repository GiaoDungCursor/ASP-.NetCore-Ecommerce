@model SV22T1020590.Models.Sales.Order
@{
    ViewData["Title"] = $"Đơn hàng #{Model.OrderID}";
    var map = ViewBag.LineProducts as Dictionary<int, SV22T1020590.Models.Catalog.Product> ?? new Dictionary<int, SV22T1020590.Models.Catalog.Product>();
    decimal total = 0m;
    if (Model.OrderDetails != null)
    {
        foreach (var d in Model.OrderDetails)
            total += d.Quantity * d.SalePrice;
    }
}

<!-- Breadcrumb -->
<nav class="d-flex mb-4 small fw-semibold" style="color: var(--st-text-muted); font-family: Inter, sans-serif;">
    <ol class="breadcrumb mb-0 align-items-center">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted transition-colors hover-primary">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted transition-colors hover-primary">Lịch sử đơn hàng</a></li>
        <li class="breadcrumb-item active text-dark" aria-current="page">Chi tiết đơn hàng</li>
    </ol>
</nav>

<!-- Main Content Card -->
<div class="bg-white mb-5" style="border-radius: 0.75rem; box-shadow: 0px 24px 48px rgba(25,28,30,0.06); overflow: hidden;">
    
    <!-- Card Header -->
    <div class="p-4 p-md-5 d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 border-bottom" style="border-color: rgba(193, 198, 215, 0.15) !important;">
        <div>
            <h1 class="fs-3 fw-bold mb-1" style="font-family: Manrope, sans-serif; color: var(--st-text);">Chi tiết đơn hàng #@Model.OrderID</h1>
            <p class="small fw-semibold mb-0 d-flex align-items-center gap-2" style="color: var(--st-text-muted); font-family: Inter, sans-serif;">
                <span class="fs-6">📅</span> Ngày lập: @Model.OrderTime.ToString("dd/MM/yyyy")
            </p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-light fw-semibold d-flex align-items-center gap-2" style="padding: 0.5rem 1.25rem; border-radius: 0.5rem; background: var(--st-surface-high);">
                <span>←</span> Quay lại
            </a>
            @if (Model.Status == "1" || Model.Status == "2")
            {
                <form asp-action="Cancel" asp-route-id="@Model.OrderID" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không? Việc này không thể hoàn tác.');" class="m-0">
                    <button type="submit" class="btn btn-danger fw-semibold d-flex align-items-center gap-2" style="padding: 0.5rem 1.25rem; border-radius: 0.5rem; background: #ba1a1a; border-color: #ba1a1a;">
                        <span>✕</span> Hủy đơn hàng
                    </button>
                </form>
            }
        </div>
    </div>

    <!-- Information Grid -->
    <div class="p-4 p-md-5" style="background: rgba(242, 244, 246, 0.3);">
        <h2 class="small fw-bold text-uppercase mb-4" style="letter-spacing: 0.1em; color: var(--st-text-muted); font-family: Manrope, sans-serif;">Thông tin đơn hàng</h2>
        
        <div class="row gy-4 gx-5" style="font-family: Inter, sans-serif;">
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Mã đơn hàng</label>
                <p class="fw-medium mb-0" style="color: var(--st-text);">@Model.OrderID</p>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Ngày lập đơn hàng</label>
                <p class="fw-medium mb-0" style="color: var(--st-text);">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Ngày duyệt/nhận đơn</label>
                <p class="fw-medium mb-0" style="color: var(--st-text);">@(Model.AcceptTime?.ToString("dd/MM/yyyy") ?? "Chưa duyệt")</p>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Khách hàng</label>
                <p class="fw-medium mb-0" style="color: var(--st-primary);">@(Model.CustomerName ?? "Khách lẻ")</p>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Tên giao dịch</label>
                <p class="fw-medium mb-0" style="color: var(--st-text);">Giao dịch #@Model.OrderID</p>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Điện thoại</label>
                <p class="fw-medium mb-0" style="color: var(--st-text);">@(Model.CustomerPhone ?? "—")</p>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Trạng thái đơn hàng</label>
                <div class="d-flex align-items-center gap-2">
                    <span class="d-inline-block rounded-circle" style="width: 8px; height: 8px; background: var(--st-primary);"></span>
                    <p class="fw-medium mb-0" style="color: var(--st-primary);">@(Model.StatusDescription ?? Model.Status)</p>
                </div>
            </div>
            
            <div class="col-12 col-lg-6 col-xl-6 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Địa chỉ giao hàng</label>
                <p class="fw-medium mb-0" style="color: var(--st-text);">@Model.DeliveryAddress</p>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Tỉnh/thành</label>
                <p class="fw-medium mb-0" style="color: var(--st-text);">@Model.DeliveryProvince</p>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 d-flex flex-column gap-1">
                <label class="small fw-semibold text-uppercase" style="letter-spacing: -0.02em; color: var(--st-text-muted); font-size: 0.75rem;">Người giao hàng</label>
                <p class="fw-medium fst-italic mb-0" style="color: var(--st-text-muted);">@(Model.ShipperName ?? "Chưa phân công")</p>
            </div>
        </div>
    </div>

    <!-- Product Table -->
    <div class="p-4 p-md-5">
        <h2 class="small fw-bold text-uppercase mb-4" style="letter-spacing: 0.1em; color: var(--st-text-muted); font-family: Manrope, sans-serif;">Danh sách mặt hàng</h2>
        
        <div class="table-responsive">
            <table class="table align-middle text-start mb-0" style="border-collapse: collapse;">
                <thead>
                    <tr style="background: var(--st-surface-low); font-family: Manrope, sans-serif;">
                        <th class="py-3 px-4 small fw-semibold text-uppercase text-muted border-0 rounded-start" style="letter-spacing: 0.05em; width: 60px;">STT</th>
                        <th class="py-3 px-4 small fw-semibold text-uppercase text-muted border-0" style="letter-spacing: 0.05em;">Tên hàng</th>
                        <th class="py-3 px-4 small fw-semibold text-uppercase text-muted border-0 text-center" style="letter-spacing: 0.05em; width: 80px;">ĐVT</th>
                        <th class="py-3 px-4 small fw-semibold text-uppercase text-muted border-0 text-end" style="letter-spacing: 0.05em; width: 100px;">Số lượng</th>
                        <th class="py-3 px-4 small fw-semibold text-uppercase text-muted border-0 text-end" style="letter-spacing: 0.05em; width: 140px;">Giá</th>
                        <th class="py-3 px-4 small fw-semibold text-uppercase text-muted border-0 text-end rounded-end" style="letter-spacing: 0.05em; width: 160px;">Thành tiền</th>
                    </tr>
                </thead>
                <tbody style="border-top: 1px solid rgba(193, 198, 215, 0.1);">
                    @if (Model.OrderDetails != null)
                    {
                        var index = 1;
                        foreach (var d in Model.OrderDetails)
                        {
                            map.TryGetValue(d.ProductID, out var p);
                            var name = p?.ProductName ?? ("Mặt hàng #" + d.ProductID);
                            var unit = p?.Unit ?? "Cái";
                            var lineAmt = d.Quantity * d.SalePrice;

                            <tr class="st-table-row" style="transition: background-color 0.2s; border-bottom: 1px solid rgba(193, 198, 215, 0.1);">
                                <td class="py-3 px-4 text-muted">@index.ToString("D2")</td>
                                <td class="py-3 px-4 fw-semibold" style="color: var(--st-text);">@name</td>
                                <td class="py-3 px-4 text-muted text-center">@unit</td>
                                <td class="py-3 px-4 text-end fw-medium">@d.Quantity</td>
                                <td class="py-3 px-4 text-end fw-medium">@d.SalePrice.ToString("N0") đ</td>
                                <td class="py-3 px-4 text-end fw-bold" style="color: var(--st-primary);">@lineAmt.ToString("N0") đ</td>
                            </tr>
                            index++;
                        }
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td class="py-4 px-4 text-end fw-bold fs-5" style="color: var(--st-text); font-family: Manrope, sans-serif;" colspan="4">Tổng cộng</td>
                        <td class="py-4 px-4 text-end fw-bolder fs-4" style="color: var(--st-primary); font-family: Manrope, sans-serif;" colspan="2">@total.ToString("N0") đ</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<style>
    .st-table-row:hover {
        background-color: rgba(242, 244, 246, 0.5);
    }
    .hover-primary:hover {
        color: var(--st-primary) !important;
    }
</style>
