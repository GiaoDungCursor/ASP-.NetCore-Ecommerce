@model ErrorViewModel
@{
    ViewData["Title"] = "Có lỗi xảy ra";
}

<div class="st-page-header mb-4">
    <h1 class="h2 text-danger">Có lỗi xảy ra</h1>
    <p>Yêu cầu của bạn chưa được xử lý thành công.</p>
</div>

<div class="st-panel p-4">
    @if (Model.ShowRequestId)
    {
        <p><strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code></p>
    }
    <p class="mb-0">Vui lòng thử lại sau hoặc quay về trang chủ.</p>
</div>
