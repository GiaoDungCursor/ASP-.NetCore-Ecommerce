@model SV22T1020590.Models.Partner.Customer
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="mb-5 mt-4 px-3">
    <h1 class="display-5 fw-bolder mb-2" style="font-family: Manrope, Inter, sans-serif; letter-spacing: -0.03em;">Hồ sơ của bạn</h1>
    <p class="text-muted fs-5">Quản lý định danh và cập nhật các thông tin cá nhân cần thiết.</p>
</div>

<div asp-validation-summary="All" class="text-danger small mb-4 px-3"></div>

<div class="row g-5">
    <div class="col-lg-8">
        <form asp-action="Profile" method="post" class="bg-white p-4 p-md-5 shadow-sm" style="border-radius: 24px; border: 1px solid rgba(193, 198, 215, 0.15);">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CustomerID" />
            
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <div class="fs-4 me-3">👤</div>
                <h2 class="h5 fw-bolder mb-0 text-uppercase" style="letter-spacing: 0.1em; color: var(--st-text-muted);">Thông tin chung</h2>
            </div>
            
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold text-uppercase" style="color: var(--st-text-muted); font-size: 0.75rem; letter-spacing: 0.05em;">Tên hiển thị</label>
                    <input asp-for="CustomerName" class="form-control form-control-lg bg-light border-0 px-3" style="border-radius: 12px; font-weight: 600;" required />
                    <span asp-validation-for="CustomerName" class="text-danger small mt-1"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold text-uppercase" style="color: var(--st-text-muted); font-size: 0.75rem; letter-spacing: 0.05em;">Tên người liên hệ</label>
                    <input asp-for="ContactName" class="form-control form-control-lg bg-light border-0 px-3" style="border-radius: 12px;" />
                </div>
                
                <div class="col-md-6">
                    <label class="form-label fw-bold text-uppercase" style="color: var(--st-text-muted); font-size: 0.75rem; letter-spacing: 0.05em;">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control form-control-lg bg-light border-0 px-3" style="border-radius: 12px;" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold text-uppercase" style="color: var(--st-text-muted); font-size: 0.75rem; letter-spacing: 0.05em;">Email đăng nhập</label>
                    <input asp-for="Email" class="form-control form-control-lg bg-light border-0 px-3" type="email" style="border-radius: 12px;" />
                    <div class="form-text mt-2 small text-muted">Dùng để khôi phục mật khẩu.</div>
                </div>
                
                <div class="col-md-6">
                    <label class="form-label fw-bold text-uppercase" style="color: var(--st-text-muted); font-size: 0.75rem; letter-spacing: 0.05em;">Tỉnh / Thành phố</label>
                    <select asp-for="Province" class="form-select form-select-lg bg-light border-0 px-3" style="border-radius: 12px;">
                        <option value="">-- Chọn tỉnh/thành --</option>
                        @foreach (var item in await SV22T1020590.BusinessLayers.DictionaryDataService.ListProvincesAsync())
                        {
                            <option value="@item.ProvinceName">@item.ProvinceName</option>
                        }
                    </select>
                </div>
                <div class="col-md-12">
                    <label class="form-label fw-bold text-uppercase" style="color: var(--st-text-muted); font-size: 0.75rem; letter-spacing: 0.05em;">Địa chỉ chi tiết</label>
                    <textarea asp-for="Address" class="form-control border-0 bg-light p-3" rows="3" style="border-radius: 12px; resize: none;"></textarea>
                </div>
            </div>
            
            <div class="mt-5 text-end">
                <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow-sm" style="border-radius: 12px; letter-spacing: 0.02em;">Cập nhật Thông tin</button>
            </div>
        </form>
    </div>
    
    <div class="col-lg-4">
        <div class="p-4 p-md-5 shadow-sm" style="background: var(--st-surface-low); border-radius: 24px;">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm fs-4 text-primary" style="width: 48px; height: 48px;">🔒</div>
                <h2 class="h5 fw-bolder mb-0" style="font-family: Manrope, Inter, sans-serif;">Bảo mật & Trợ giúp</h2>
            </div>
            
            <p class="text-muted mb-4 fw-semibold" style="line-height: 1.6;">Đăng nhập định kỳ và bảo vệ tài khoản bằng việc thay đổi mật khẩu thường xuyên.</p>
            
            <a class="btn btn-dark w-100 btn-lg fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2 mb-3" asp-action="ChangePassword" style="border-radius: 12px;">
                Cập nhật mật khẩu <span>&rarr;</span>
            </a>
            
            <div class="mt-4 pt-4 border-top">
                <p class="small text-muted mb-0 fw-bold">Cần hỗ trợ?</p>
                <a href="#" class="text-primary text-decoration-none fw-bolder">Liên hệ với CSKH</a>
            </div>
        </div>
    </div>
</div>
