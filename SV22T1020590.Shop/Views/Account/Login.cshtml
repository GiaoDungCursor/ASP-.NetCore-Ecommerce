@{
    ViewData["Title"] = "Đăng nhập";
    var returnUrl = ViewData["ReturnUrl"] as string;
}
<div class="row justify-content-center pt-md-5 pb-5">
    <div class="col-md-6 col-lg-5">
        <div class="st-auth-card p-4 p-md-5 bg-white shadow-lg" style="border-radius: 24px; border: 1px solid rgba(193,198,215,0.15);">
            <div class="text-center mb-5">
                <h1 class="fw-bolder mb-2" style="font-family: Manrope, Inter, sans-serif; letter-spacing: -0.03em; color: var(--st-text);">Chào mừng trở lại</h1>
                <p class="small" style="color: var(--st-text-muted);">Đăng nhập để tiếp tục mua sắm và theo dõi đơn hàng.</p>
            </div>
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>
            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <div class="mb-4">
                    <label class="form-label fw-bold text-uppercase" style="color: var(--st-text-muted); font-size: 0.75rem; letter-spacing: 0.05em;">Email</label>
                    <input type="email" name="email" class="form-control form-control-lg px-3 py-2 bg-light" style="border-radius: 12px; border: 1px solid rgba(193,198,215,0.3);" required placeholder="name@example.com" />
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label fw-bold text-uppercase mb-0" style="color: var(--st-text-muted); font-size: 0.75rem; letter-spacing: 0.05em;">Mật khẩu</label>
                        <a href="javascript:;" class="small text-decoration-none fw-bold" style="color: var(--st-primary);">Quên mật khẩu?</a>
                    </div>
                    <input type="password" name="password" class="form-control form-control-lg px-3 py-2 bg-light mt-2" style="border-radius: 12px; border: 1px solid rgba(193,198,215,0.3);" required placeholder="••••••••" />
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm mt-3" style="border-radius: 12px; letter-spacing: 0.02em;">Đăng nhập</button>
            </form>
            <div class="text-center mt-5">
                <p class="small" style="color: var(--st-text-muted);">Chưa có tài khoản? <a asp-action="Register" class="fw-bold text-decoration-none" style="color: var(--st-primary);">Tạo thiết lập mới</a></p>
            </div>
        </div>
    </div>
</div>
